prefix=D:/a/libjxl/libjxl/x86-windows-static
exec_prefix=D:/a/libjxl/libjxl/x86-windows-static
libdir=${prefix}/lib
includedir=${prefix}/include

Name: libbrotlidec
URL: https://github.com/google/brotli
Description: Brotli decoder library
Version: 1.2.0
Libs: -L${libdir} -lbrotlidec
Requires.private: libbrotlicommon >= 1.2.0
Cflags: -I${includedir}
